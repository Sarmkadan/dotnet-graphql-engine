<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Updated to a valid target framework -->
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <PackageId>Zaiets.dotnet.graphql.engine</PackageId>
    <Version>1.0.0</Version>
    <Title>dotnet-graphql-engine</Title>
    <Description>A high-performance code-first GraphQL engine for .NET, supporting schema stitching, DataLoader, subscriptions, and query complexity analysis.</Description>
    <Authors>Vladyslav Zaiets</Authors>
    <PackageTags>graphql dotnet schema-stitching dataloader subscriptions complexity</PackageTags>
    <PackageProjectUrl>https://github.com/sarmkadan/dotnet-graphql-engine</PackageProjectUrl>
    <RepositoryUrl>https://github.com/sarmkadan/dotnet-graphql-engine</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <!-- Include all source files but explicitly exclude benchmarks, examples and tests -->
    <Compile Include="**/*.cs"
             Exclude="benchmarks/**/*.cs;examples/**/*.cs;tests/**/*.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.10" />
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging" Version="10.0.10" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="10.0.0" />
    <PackageReference Include="System.Collections.Concurrent" Version="4.3.0" />
    <PackageReference Include="System.Reflection" Version="4.3.0" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="wwwroot\" />
  </ItemGroup>

</Project>
